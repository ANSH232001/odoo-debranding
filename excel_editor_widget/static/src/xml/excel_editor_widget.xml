<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ── Main field widget ── -->
    <t t-name="excel_editor_widget.ExcelEditorWidget" owl="1">
        <div class="o_excel_editor_widget">

            <!-- Viewer rendered as a direct child (same pattern as CameraCapture)
                 so t-ref inside SpreadsheetViewer's own template works correctly -->
            <SpreadsheetViewer t-if="state.viewerOpen and state.viewerB64"
                base64Data="state.viewerB64"
                filename="state.filename or 'spreadsheet.xlsx'"
                onSave.bind="onSave"
                onClose.bind="closeViewer"/>

            <!-- File present -->
            <t t-if="state.hasData">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="fa fa-file-excel-o fa-lg text-success"/>
                    <span class="fw-medium text-truncate" style="max-width:220px;"
                          t-esc="state.filename"/>
                </div>
                <div class="d-flex gap-1 flex-wrap">
                    <button class="btn btn-primary btn-sm" t-on-click="openViewer">
                        <i class="fa fa-pencil me-1"/> Edit
                    </button>
                    <button class="btn btn-secondary btn-sm" t-on-click="download">
                        <i class="fa fa-download me-1"/> Download
                    </button>
                    <button class="btn btn-danger btn-sm" t-on-click="clearFile"
                            t-if="!isReadonly">
                        <i class="fa fa-trash"/>
                    </button>
                </div>
            </t>

            <!-- No file -->
            <t t-if="!state.hasData and !isReadonly">
                <button class="btn btn-secondary btn-sm" t-on-click="triggerUpload">
                    <i class="fa fa-upload me-1"/> Upload Excel
                </button>
            </t>

            <input t-ref="uploadInput" type="file"
                   accept=".xls,.xlsx,.xlsm,.xlsb"
                   class="d-none" t-on-change="onUpload"/>
        </div>
    </t>

    <!-- ── SpreadsheetViewer: full-screen fixed overlay ── -->
    <t t-name="excel_editor_widget.SpreadsheetViewer" owl="1">
        <div class="position-fixed top-0 start-0 w-100"
             style="height:100vh;z-index:9999;background:rgba(0,0,0,0.5);display:flex;flex-direction:column;">

            <!-- Toolbar -->
            <div class="d-flex align-items-center gap-2 px-3 py-2 flex-shrink-0"
                 style="background:#fff;border-bottom:2px solid #dee2e6;">
                <i class="fa fa-file-excel-o text-success fa-lg"/>
                <span class="fw-bold me-auto text-truncate" style="max-width:500px;"
                      t-esc="props.filename"/>

                <!-- Close (auto-saves any changes) -->
                <t t-if="state.mode !== 'error'">
                    <button t-att-class="'btn btn-sm ' + (state.mode === 'loading' ? 'btn-success' : 'btn-danger')"
                            t-att-disabled="state.mode === 'loading'"
                            t-on-click="close">
                        <t t-if="state.mode === 'loading'">
                            <i class="fa fa-spinner fa-spin me-1"/> Loading…
                        </t>
                        <t t-else="">
                            <i class="fa fa-times-circle me-1"/> Close
                        </t>
                    </button>
                </t>

                <t t-if="state.mode === 'error'">
                    <button class="btn btn-sm btn-light border" t-on-click="close">
                        <i class="fa fa-times"/>
                    </button>
                </t>
            </div>

            <!-- Content area: always rendered so t-ref is immediately available.
                 min-height:0 is required in flexbox so overflow:auto can scroll. -->
            <div style="flex:1;min-height:0;overflow:auto;background:#f5f5f5;position:relative;">

                <!-- Loading spinner (sits on top until ready) -->
                <div t-if="state.mode === 'loading'"
                     class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                     style="background:rgba(255,255,255,0.9);z-index:5;">
                    <div class="text-center">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3"/>
                        <div class="text-muted">Loading spreadsheet…</div>
                    </div>
                </div>

                <!-- Error state -->
                <div t-if="state.mode === 'error'"
                     class="d-flex align-items-center justify-content-center h-100">
                    <div class="alert alert-danger m-4">
                        <i class="fa fa-exclamation-circle me-2"/>
                        Could not parse this file. Try downloading and opening in Excel.
                    </div>
                </div>

                <!--
                    THE KEY: t-ref="content" is NOT inside any t-if.
                    It is always rendered, so onMounted() can access contentRef.el
                    immediately — no timing issues, no slot-wrapper ref problems.
                    The HTML table + image overlays are injected here via _renderContent().
                -->
                <div t-ref="content"
                     style="padding:12px;position:relative;"/>
            </div>
        </div>
    </t>

</templates>
